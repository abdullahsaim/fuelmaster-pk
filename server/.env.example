# ─── FuelMaster PK — Environment Configuration ───
# Copy this file to .env and update values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/fuelmaster_pk
# Atlas: mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/fuelmaster_pk
MONGO_URI=mongodb://localhost:27017/fuelmaster_pk

# JWT Authentication
JWT_SECRET=fuelmaster_pk_super_secret_key_change_in_production_2026
JWT_EXPIRE=30d

# CORS — Frontend URL
CLIENT_URL=http://localhost:3000

# Upload Directory
UPLOAD_PATH=./uploads
